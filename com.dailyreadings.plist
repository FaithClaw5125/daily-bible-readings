<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dailyreadings</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/clawfaith/.openclaw/workspace/daily_readings/daily_readings.py</string>
    </array>

    <!-- Run every day at 7:00 AM local time -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/clawfaith/.openclaw/workspace/daily_readings/run.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/clawfaith/.openclaw/workspace/daily_readings/error.log</string>

    <!-- Run even if the scheduled time was missed (e.g. machine was asleep) -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
